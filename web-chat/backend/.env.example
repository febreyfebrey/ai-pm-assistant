# Anthropic API Key — 從 https://console.anthropic.com/ 取得
ANTHROPIC_API_KEY=
# Port
PORT=3002

# 前端允許的 origin（CORS）
ALLOWED_ORIGIN=http://localhost:3000

# ==============================
# Jira API 整合（即時查詢 group 成員）
# ==============================
# 從 https://id.atlassian.com/manage-profile/security/api-tokens 建立 API Token
# 沒設定時，backend 會 fallback 到 data/allowed-reporters.json（靜態清單）

JIRA_BASE_URL=https://tutorabc-org.atlassian.net
JIRA_EMAIL=febreyhuang@tutorabc.com
JIRA_API_TOKEN=

# ==============================
# Teams Webhook（選用，測試通過時通知）
# ==============================
# TEAMS_WEBHOOK_URL=https://tutorabc.webhook.office.com/...
